# n8n connection
N8N_API_URL=https://your-n8n-instance.com/api/v1
N8N_API_KEY=your_n8n_api_key_here

# Supabase (PostgreSQL)
# Find these in: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Slack alerts
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#n8n-health-alerts

# Environment label (e.g. production, staging, dev)
ENVIRONMENT=production

# Input mode: "api" or "file"
INPUT_MODE=api

# If INPUT_MODE=file, path to folder containing exported workflow JSON files
WORKFLOW_DIR=./workflows
